  %% Plan to Software
  Objectives --> Define_Params
  Define_Params --> Document_Notebook
  Document_Notebook --> Set_Experiment_Name
  Set_Experiment_Name --> Install_Dependencies

  %% Software setup
  Install_Dependencies --> Import_Libraries
  Import_Libraries --> Start_mlflow_autolog

  %% Software to Ops
  Import_Libraries --> Start_MLflow_UI
  Start_mlflow_autolog --> Configure_MLflow_Experiment

  %% Ops setup
  Start_MLflow_UI --> Setup_ngrok_Tunnel
  Setup_ngrok_Tunnel --> Configure_MLflow_Experiment
  Configure_MLflow_Experiment --> Artifact_Storage

  %% Ops to Data
  Configure_MLflow_Experiment --> Download_Dataset

  %% Data processing flow
  Download_Dataset --> Data_Transform_Normalize
  Data_Transform_Normalize --> Create_DataLoaders

  %% Data to Model
  Create_DataLoaders --> Define_Model_Architecture
  Define_Model_Architecture --> Define_Loss_And_Optimizer

  %% Experiment loop
  Define_Loss_And_Optimizer --> Hyperparameter_Tuning_Loop
  Hyperparameter_Tuning_Loop --> Train_Function
  Hyperparameter_Tuning_Loop --> Test_Function
  Train_Function --> Log_Params_Metrics
  Test_Function --> Log_Params_Metrics

  %% Logging and persistence
  Log_Params_Metrics --> Log_Model_To_MLflow
  Log_Model_To_MLflow --> Artifact_Storage
  Artifact_Storage --> Load_Model_From_MLflow

  %% Post training analysis
  Load_Model_From_MLflow --> Model_Evaluation
  Model_Evaluation --> Visualize_Weights_And_ConfusionMatrix

  %% Iteration loop
  Visualize_Weights_And_ConfusionMatrix --> Define_Params
  Visualize_Weights_And_ConfusionMatrix --> Hyperparameter_Tuning_Loop